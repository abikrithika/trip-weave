{
  "name": "trip-weave",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "api/src/server.js",
  "scripts": {
    "dev": "prisma generate --schema=./api/src/db/code/schema.prisma && nodemon api/src/server.js",
    "start": "node api/src/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:extract": "node api/src/groq/testExtract.js",
    "test:extract:normalize": "node api/src/groq/testNormalize.js",
    "db:generate": "prisma generate --schema=./api/src/db/code/schema.prisma",
    "db:validate": "prisma validate --schema=./api/src/db/code/schema.prisma",
    "db:create": "node api/src/db/code/ensureDatabase.js",
    "db:migrate": "prisma migrate dev --schema=./api/src/db/code/schema.prisma",
    "db:seed": "node api/src/db/code/seed.js",
    "db:deploy": "prisma migrate deploy --schema=./api/src/db/code/schema.prisma",
    "db:all": "cd api/src/db && npm run db:create && npm run db:validate && npm run db:migrate && npm run db:generate && npm run db:seed",
    "start:frontend": "http-server app",
    "standalone": "concurrently \"npm run start:frontend\" \"npm run dev\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abikrithika/trip-weave.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/abikrithika/trip-weave/issues"
  },
  "homepage": "https://github.com/abikrithika/trip-weave#readme",
  "dependencies": {
    "@ai-sdk/groq": "^3.0.41",
    "@prisma/client": "^4.16.2",
    "airports-json": "^1.0.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^2.1.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "geoip-lite": "^2.0.3",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "request-ip": "^3.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "http-server": "^14.1.1",
    "nodemon": "^3.1.14",
    "prisma": "^4.16.2"
  },
  "prisma": {
    "seed": "node api/src/db/code/seed.js"
  }
}
